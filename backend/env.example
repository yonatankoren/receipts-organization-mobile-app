# Copy this file to .env and fill in your values
# Google Cloud Vision - set GOOGLE_APPLICATION_CREDENTIALS to your service account JSON path
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# LLM API Key (OpenAI)
OPENAI_API_KEY=sk-...

# Optional: LLM model override
LLM_MODEL=gpt-4o

# Server
HOST=0.0.0.0
PORT=8080

